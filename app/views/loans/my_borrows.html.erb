<%# My Borrows — Stitch Premium Activity Page %>
<div class="space-y-8 animate-fade-in-up">

  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="font-headline-lg text-2xl sm:text-3xl text-on-surface">Activity</h1>
      <p class="font-body-base text-sm text-secondary">Track your borrowing and lending history</p>
    </div>
    <%= link_to new_item_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-on-primary rounded-full font-label-caps text-xs tracking-wider transition-all hover:brightness-110 shadow-md active:scale-95 duration-200" do %>
      <span class="material-symbols-outlined text-[16px]">add</span>
      LEND ITEM
    <% end %>
  </div>

  <%# Tab Navigation %>
  <div class="tab-nav">
    <%= link_to my_borrows_loans_path, class: "tab-item active" do %>
      <span class="material-symbols-outlined text-base">swap_horiz</span>
      My Borrows
    <% end %>
    <%= link_to my_lends_loans_path, class: "tab-item" do %>
      <span class="material-symbols-outlined text-base">handshake</span>
      My Lends
    <% end %>
  </div>

  <%# Loans List %>
  <% if @loans.any? %>
    <div class="space-y-4">
      <% @loans.each do |loan| %>
        <div class="bg-surface-container-lowest border border-outline-variant/20 rounded-2xl p-5 shadow-sm smooth-lift flex items-center justify-between gap-4">
          <div class="flex items-center gap-4 min-w-0">
            <%# Item thumbnail %>
            <% if loan.item.images.attached? %>
              <%= image_tag loan.item.thumbnail.variant(resize_to_fill: [64, 64]),
                  class: "w-16 h-16 rounded-xl object-cover flex-shrink-0 border border-outline-variant/20 shadow-sm" %>
            <% else %>
              <div class="w-16 h-16 rounded-xl bg-surface-container/30 flex items-center justify-center flex-shrink-0 border border-outline-variant/20">
                <span class="material-symbols-outlined text-outline text-2xl">image</span>
              </div>
            <% end %>

            <%# Item info %>
            <div class="min-w-0">
              <%= link_to loan.item.name, item_path(loan.item), class: "font-bold text-sm text-on-surface hover:text-primary transition-colors truncate block" %>
              <p class="text-xs text-secondary font-medium mt-0.5">From: <span class="font-bold text-on-surface"><%= loan.item.user.name %></span></p>
              <p class="text-xs text-outline mt-1 font-semibold flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                <%= loan.start_date.strftime("%b %d") %> – <%= loan.end_date.strftime("%b %d, %Y") %>
              </p>
            </div>
          </div>

          <%# Status Badge %>
          <span class="badge flex-shrink-0
            <%= case loan.status
                when 'pending' then 'badge-warning'
                when 'approved' then 'badge-info'
                when 'active' then 'badge-success'
                when 'returned' then 'badge-neutral'
                when 'declined' then 'badge-danger'
                end %>">
            <%= loan.status.titleize %>
          </span>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state bg-surface-container-lowest rounded-2xl border border-outline-variant/20 shadow-sm py-16">
      <div class="empty-state-icon mx-auto">
        <span class="material-symbols-outlined text-primary text-4xl">shopping_cart</span>
      </div>
      <h3 class="text-lg font-bold text-on-surface mt-4 mb-2">No borrows yet</h3>
      <p class="text-secondary text-sm max-w-sm mx-auto leading-relaxed">You haven't borrowed anything yet. Browse the catalog to find tools and gear from your neighbors.</p>
      <%= link_to root_path, class: "mt-6 inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary rounded-full font-label-caps text-xs tracking-wider transition-all hover:brightness-110 shadow-md active:scale-95" do %>
        BROWSE ITEMS
      <% end %>
    </div>
  <% end %>
</div>

