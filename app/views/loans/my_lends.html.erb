<%# My Lends — Stitch Premium Activity Page %>
<div class="space-y-8 animate-fade-in-up">

  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="font-headline-lg text-2xl sm:text-3xl text-on-surface">Activity</h1>
      <p class="font-body-base text-sm text-secondary">Manage your lending activity</p>
    </div>
    <%= link_to new_item_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-on-primary rounded-full font-label-caps text-xs tracking-wider transition-all hover:brightness-110 shadow-md active:scale-95 duration-200" do %>
      <span class="material-symbols-outlined text-[16px]">add</span>
      LEND ITEM
    <% end %>
  </div>

  <%# Tab Navigation %>
  <div class="tab-nav">
    <%= link_to my_borrows_loans_path, class: "tab-item" do %>
      <span class="material-symbols-outlined text-base">swap_horiz</span>
      My Borrows
    <% end %>
    <%= link_to my_lends_loans_path, class: "tab-item active" do %>
      <span class="material-symbols-outlined text-base">handshake</span>
      My Lends
    <% end %>
  </div>

  <%# Loans List %>
  <% if @loans.any? %>
    <div class="space-y-4">
      <% @loans.each do |loan| %>
        <div class="bg-surface-container-lowest border border-outline-variant/20 rounded-2xl p-5 shadow-sm smooth-lift flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div class="flex items-center gap-4 min-w-0">
            <%# Borrower avatar %>
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-500 flex items-center justify-center flex-shrink-0 shadow-sm">
              <span class="text-white text-sm font-bold"><%= loan.borrower.name.first.upcase %></span>
            </div>

            <%# Loan info %>
            <div class="min-w-0">
              <%= link_to loan.item.name, item_path(loan.item), class: "font-bold text-sm text-on-surface hover:text-primary transition-colors truncate block" %>
              <p class="text-xs text-secondary font-medium mt-0.5">
                Requested by <span class="font-bold text-on-surface"><%= loan.borrower.name %></span>
              </p>
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1.5">
                <p class="text-xs text-outline font-semibold flex items-center gap-1">
                  <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                  <%= loan.start_date.strftime("%b %d") %> – <%= loan.end_date.strftime("%b %d, %Y") %>
                </p>
                <% if loan.message.present? %>
                  <span class="text-xs text-outline italic truncate max-w-[200px]">"<%= truncate(loan.message, length: 50) %>"</span>
                <% end %>
              </div>
            </div>
          </div>

          <%# Actions %>
          <div class="flex items-center gap-3 flex-shrink-0">
            <span class="badge flex-shrink-0
              <%= case loan.status
                  when 'pending' then 'badge-warning'
                  when 'approved' then 'badge-info'
                  when 'active' then 'badge-success'
                  when 'returned' then 'badge-neutral'
                  when 'declined' then 'badge-danger'
                  end %>">
              <%= loan.status.titleize %>
            </span>

            <% if loan.pending? %>
              <div class="flex gap-1.5">
                <%= button_to "Approve", approve_item_loan_path(loan.item, loan), method: :patch,
                    class: "px-3 py-1.5 bg-primary text-on-primary rounded-lg font-label-caps text-[10px] font-extrabold tracking-wider hover:brightness-110 active:scale-95 cursor-pointer" %>
                <%= button_to "Decline", decline_item_loan_path(loan.item, loan), method: :patch,
                    class: "px-3 py-1.5 border border-outline-variant/50 text-secondary rounded-lg font-label-caps text-[10px] font-extrabold tracking-wider hover:bg-surface-container/50 active:scale-95 cursor-pointer" %>
              </div>
            <% elsif loan.approved? %>
              <%= button_to activate_item_loan_path(loan.item, loan), method: :patch,
                  class: "px-4 py-1.5 bg-primary text-on-primary rounded-lg font-label-caps text-[10px] font-extrabold tracking-wider hover:brightness-110 active:scale-95 cursor-pointer" do %>
                Mark Handed Over
              <% end %>
            <% elsif loan.active? %>
              <%= button_to return_item_item_loan_path(loan.item, loan), method: :patch,
                  class: "px-4 py-1.5 text-[10px] font-extrabold tracking-wider text-blue-600 border border-blue-200 rounded-lg hover:bg-blue-50 transition-colors cursor-pointer font-label-caps" do %>
                Mark Returned
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state bg-surface-container-lowest rounded-2xl border border-outline-variant/20 shadow-sm py-16">
      <div class="empty-state-icon mx-auto">
        <span class="material-symbols-outlined text-primary text-4xl">handshake</span>
      </div>
      <h3 class="text-lg font-bold text-on-surface mt-4 mb-2">No lending activity</h3>
      <p class="text-secondary text-sm max-w-sm mx-auto leading-relaxed">No one has requested your items yet. Share your first item to get started!</p>
      <%= link_to new_item_path, class: "mt-6 inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary rounded-full font-label-caps text-xs tracking-wider transition-all hover:brightness-110 shadow-md active:scale-95" do %>
        <span class="material-symbols-outlined text-[16px]">add</span>
        SHARE AN ITEM
      <% end %>
    </div>
  <% end %>
</div>

