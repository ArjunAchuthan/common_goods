<%# My Lends — Premium Activity Page %>
<div class="space-y-6 animate-fade-in-up">

  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight">Activity</h1>
      <p class="text-sm text-slate-500 dark:text-slate-400 font-medium mt-1">Manage your lending activity</p>
    </div>
    <%= link_to new_item_path, class: "btn-primary text-sm w-fit" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
      Share Item
    <% end %>
  </div>

  <%# Tab Navigation %>
  <div class="tab-nav">
    <%= link_to my_borrows_loans_path, class: "tab-item" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>
      My Borrows
    <% end %>
    <%= link_to my_lends_loans_path, class: "tab-item active" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      My Lends
    <% end %>
  </div>

  <%# Loans List %>
  <% if @loans.any? %>
    <div class="space-y-3">
      <% @loans.each do |loan| %>
        <div class="activity-card">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div class="flex items-center gap-4 min-w-0">
              <%# Borrower avatar %>
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-500 flex items-center justify-center flex-shrink-0 shadow-sm shadow-blue-500/15">
                <span class="text-white text-sm font-bold"><%= loan.borrower.name.first.upcase %></span>
              </div>

              <%# Loan info %>
              <div class="min-w-0">
                <%= link_to loan.item.name, item_path(loan.item), class: "font-bold text-sm text-slate-800 dark:text-white hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors truncate block" %>
                <p class="text-xs text-slate-500 dark:text-slate-400 font-medium mt-0.5">
                  Requested by <span class="font-semibold text-slate-600 dark:text-slate-300"><%= loan.borrower.name %></span>
                </p>
                <div class="flex items-center gap-3 mt-1">
                  <p class="text-xs text-slate-400 font-medium">
                    <svg class="w-3 h-3 inline-block mr-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <%= loan.start_date.strftime("%b %d") %> – <%= loan.end_date.strftime("%b %d, %Y") %>
                  </p>
                  <% if loan.message.present? %>
                    <span class="text-xs text-slate-400 italic truncate max-w-[200px]">"<%= truncate(loan.message, length: 60) %>"</span>
                  <% end %>
                </div>
              </div>
            </div>

            <%# Actions %>
            <div class="flex items-center gap-2 flex-shrink-0">
              <span class="badge
                <%= case loan.status
                    when 'pending' then 'badge-warning'
                    when 'approved' then 'badge-info'
                    when 'active' then 'badge-success'
                    when 'returned' then 'badge-neutral'
                    when 'declined' then 'badge-danger'
                    end %>">
                <%= loan.status.titleize %>
              </span>

              <% if loan.pending? %>
                <div class="flex gap-1.5">
                  <%= button_to "Approve", approve_item_loan_path(loan.item, loan), method: :patch,
                      class: "px-3 py-1.5 btn-primary text-xs cursor-pointer" %>
                  <%= button_to "Decline", decline_item_loan_path(loan.item, loan), method: :patch,
                      class: "px-3 py-1.5 btn-secondary text-xs cursor-pointer" %>
                </div>
              <% elsif loan.approved? %>
                <%= button_to "Mark Handed Over", activate_item_loan_path(loan.item, loan), method: :patch,
                    class: "px-3 py-1.5 btn-primary text-xs cursor-pointer" %>
              <% elsif loan.active? %>
                <%= button_to "Mark Returned", return_item_item_loan_path(loan.item, loan), method: :patch,
                    class: "px-3 py-1.5 text-xs font-semibold text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-800/40 rounded-xl hover:bg-blue-50 dark:hover:bg-blue-950/20 transition-colors cursor-pointer" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state bg-white dark:bg-slate-900 rounded-2xl border border-slate-200/50 dark:border-slate-800/40">
      <div class="empty-state-icon">
        <svg class="w-8 h-8 text-emerald-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <h3 class="text-lg font-bold text-slate-700 dark:text-slate-200 mb-1">No lending activity</h3>
      <p class="text-sm text-slate-400 dark:text-slate-500 max-w-sm">No one has requested your items yet. Share your first item to get started!</p>
      <%= link_to new_item_path, class: "mt-5 btn-primary text-sm" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
        Share an Item
      <% end %>
    </div>
  <% end %>
</div>
