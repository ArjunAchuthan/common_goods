<%# Notifications Index — Premium Page %>
<div class="max-w-2xl mx-auto space-y-6 animate-fade-in-up">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight">Notifications</h1>
      <p class="text-sm text-slate-500 dark:text-slate-400 font-medium mt-1">Stay updated on your activity</p>
    </div>
    <% if current_user.notifications.unread.any? %>
      <%= button_to "Mark all read", mark_all_read_notifications_path, method: :post,
          class: "btn-secondary text-xs cursor-pointer" %>
    <% end %>
  </div>

  <% if @notifications.any? %>
    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200/50 dark:border-slate-800/40 overflow-hidden divide-y divide-slate-100 dark:divide-slate-800/50 shadow-sm">
      <% @notifications.each do |notification| %>
        <%= render notification %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state bg-white dark:bg-slate-900 rounded-2xl border border-slate-200/50 dark:border-slate-800/40">
      <div class="empty-state-icon">
        <svg class="w-8 h-8 text-emerald-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
        </svg>
      </div>
      <h3 class="text-lg font-bold text-slate-700 dark:text-slate-200 mb-1">All caught up!</h3>
      <p class="text-sm text-slate-400 dark:text-slate-500">No notifications yet. Activity will appear here.</p>
    </div>
  <% end %>
</div>
