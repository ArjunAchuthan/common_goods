<%# Item Show Page — Premium Detail View %>
<div class="max-w-6xl mx-auto space-y-6 animate-fade-in-up">

  <%# Breadcrumb Nav %>
  <div>
    <%= link_to items_path, class: "inline-flex items-center gap-2 text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors group" do %>
      <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to Browse
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start">

    <%# Left Column: Gallery %>
    <div class="lg:col-span-7 bg-white dark:bg-slate-900 rounded-2xl border border-slate-200/50 dark:border-slate-800/40 shadow-sm overflow-hidden">

      <%# Main Image %>
      <div class="aspect-[4/3] bg-gradient-to-br from-slate-100 to-slate-50 dark:from-slate-800 dark:to-slate-850 relative flex items-center justify-center">
        <% if @item.images.attached? %>
          <%= image_tag @item.images.first.variant(resize_to_limit: [800, 600]),
              class: "w-full h-full object-cover", alt: @item.name %>
        <% else %>
          <div class="flex flex-col items-center gap-3 text-slate-300 dark:text-slate-600">
            <svg class="w-16 h-16 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <span class="text-xs font-bold uppercase tracking-wider opacity-50">No photos uploaded</span>
          </div>
        <% end %>
      </div>

      <%# Thumbnail Grid %>
      <% if @item.images.attached? && @item.images.count > 1 %>
        <div class="flex gap-2 p-4 overflow-x-auto">
          <% @item.images.each do |image| %>
            <div class="w-20 h-20 rounded-xl overflow-hidden cursor-pointer hover:ring-2 hover:ring-emerald-500 transition-all duration-200 border border-slate-100 dark:border-slate-800 flex-shrink-0">
              <%= image_tag image.variant(resize_to_fill: [150, 150]), class: "w-full h-full object-cover" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Description %>
      <div class="p-6 border-t border-slate-100 dark:border-slate-800/60">
        <h2 class="text-lg font-bold text-slate-800 dark:text-white mb-3">About This Item</h2>
        <p class="text-slate-600 dark:text-slate-300 leading-relaxed text-sm font-medium">
          <%= @item.description %>
        </p>
      </div>
    </div>

    <%# Right Column: Details & Booking %>
    <div class="lg:col-span-5 space-y-5 sticky-sidebar-card">

      <%# Main Details Card %>
      <div class="form-card p-6 space-y-5">

        <%# Header %>
        <div class="flex justify-between items-start gap-4">
          <div class="space-y-2.5">
            <span class="badge badge-success">
              <%= @item.category.titleize %>
            </span>
            <h1 class="text-2xl sm:text-3xl font-black text-slate-900 dark:text-white tracking-tight leading-none">
              <%= @item.name %>
            </h1>
          </div>
          <% if @item.user_id == current_user&.id %>
            <%= link_to edit_item_path(@item), class: "p-2.5 rounded-xl border border-slate-200 dark:border-slate-700 text-slate-400 hover:text-emerald-500 hover:border-emerald-500/30 hover:bg-emerald-50 dark:hover:bg-emerald-950/20 transition-all duration-200" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            <% end %>
          <% end %>
        </div>

        <%# Condition %>
        <div class="flex items-center gap-3 text-sm">
          <span class="text-slate-500 dark:text-slate-400 font-semibold">Condition:</span>
          <span class="badge
            <%= @item.condition == 'like_new' ? 'badge-success' :
                @item.condition == 'good' ? 'badge-info' :
                @item.condition == 'fair' ? 'badge-warning' :
                'badge-neutral' %>">
            <%= @item.condition.titleize %>
          </span>
        </div>

        <%# Owner Card %>
        <div class="flex items-center gap-3.5 p-4 rounded-xl bg-slate-50/80 dark:bg-slate-800/40 border border-slate-100 dark:border-slate-800/50">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center shadow-md shadow-purple-500/15">
            <span class="text-white font-bold text-sm"><%= @item.user.name.first.upcase %></span>
          </div>
          <div>
            <p class="font-bold text-sm text-slate-800 dark:text-white"><%= @item.user.name %></p>
            <p class="text-xs text-slate-400 font-medium">
              <% if @item.user.neighborhood %>
                <%= @item.user.neighborhood.name %> ·
              <% end %>
              Listed <%= time_ago_in_words(@item.created_at) %> ago
            </p>
          </div>
        </div>

        <%# Booking Form %>
        <% if user_signed_in? && @item.user_id != current_user.id && @item.available? %>
          <%= turbo_frame_tag "loan_form" do %>
            <div class="border-t border-slate-100 dark:border-slate-800/60 pt-5 space-y-4" data-controller="booking">
              <h3 class="font-bold text-slate-800 dark:text-white text-base flex items-center gap-2">
                <svg class="w-4.5 h-4.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                Request to Borrow
              </h3>

              <%= form_with model: @loan, url: item_loans_path(@item), class: "space-y-3.5" do |f| %>
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <%= f.label :start_date, "Pick Up", class: "block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5" %>
                    <%= f.date_field :start_date, min: Date.current,
                        class: "w-full px-3 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50 text-sm font-medium focus:bg-white dark:focus:bg-slate-800 transition-all",
                        data: { booking_target: "startDate", action: "change->booking#validateDates" } %>
                  </div>
                  <div>
                    <%= f.label :end_date, "Return By", class: "block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5" %>
                    <%= f.date_field :end_date, min: Date.current + 1,
                        class: "w-full px-3 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50 text-sm font-medium focus:bg-white dark:focus:bg-slate-800 transition-all",
                        data: { booking_target: "endDate", action: "change->booking#validateDates" } %>
                  </div>
                </div>
                <div>
                  <%= f.label :message, "Note for lender", class: "block text-xs font-semibold text-slate-500 dark:text-slate-400 mb-1.5" %>
                  <%= f.text_area :message, rows: 2, placeholder: "What's your project?",
                      class: "w-full px-3 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50 text-sm font-medium placeholder-slate-400 focus:bg-white dark:focus:bg-slate-800 resize-none transition-all" %>
                </div>
                <%= f.submit "Submit Request", class: "w-full py-3 btn-primary text-sm font-bold cursor-pointer",
                    data: { booking_target: "submitBtn" } %>
              <% end %>
            </div>
          <% end %>
        <% elsif !@item.available? %>
          <div class="p-4 rounded-xl bg-amber-50 dark:bg-amber-950/20 border border-amber-200/50 dark:border-amber-800/30 flex items-center gap-3">
            <svg class="w-5 h-5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm font-semibold text-amber-700 dark:text-amber-300">Currently on loan — check back later!</p>
          </div>
        <% end %>

        <%# Pending Requests (Item Owner) %>
        <% if @item.user_id == current_user&.id && @item.pending_requests.any? %>
          <div class="border-t border-slate-100 dark:border-slate-800/60 pt-5 space-y-4">
            <h3 class="font-bold text-slate-800 dark:text-white text-base flex items-center gap-2">
              <svg class="w-4.5 h-4.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Pending Requests (<%= @item.pending_requests.count %>)
            </h3>
            <div class="space-y-3">
              <% @item.pending_requests.includes(:borrower).each do |loan| %>
                <div class="activity-card space-y-3">
                  <div class="flex justify-between items-center">
                    <div class="flex items-center gap-2">
                      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-500 flex items-center justify-center">
                        <span class="text-white text-xs font-bold"><%= loan.borrower.name.first.upcase %></span>
                      </div>
                      <div>
                        <p class="font-bold text-sm text-slate-800 dark:text-white"><%= loan.borrower.name %></p>
                        <p class="text-xs text-emerald-600 dark:text-emerald-400 font-semibold"><%= loan.start_date.strftime("%b %d") %> – <%= loan.end_date.strftime("%b %d") %></p>
                      </div>
                    </div>
                  </div>
                  <% if loan.message.present? %>
                    <p class="text-xs text-slate-500 dark:text-slate-400 italic bg-slate-50 dark:bg-slate-800/50 p-3 rounded-lg border border-slate-100 dark:border-slate-800/40">
                      "<%= loan.message %>"
                    </p>
                  <% end %>
                  <div class="flex gap-2">
                    <%= button_to "Approve", approve_item_loan_path(@item, loan), method: :patch,
                        class: "flex-1 py-2 btn-primary text-xs cursor-pointer" %>
                    <%= button_to "Decline", decline_item_loan_path(@item, loan), method: :patch,
                        class: "px-4 py-2 btn-secondary text-xs cursor-pointer" %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

      </div>
    </div>

  </div>
</div>
