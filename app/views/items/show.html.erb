<%# Item Show Page — Stitch Details View %>
<div class="space-y-6 animate-fade-in-up">

  <%# Breadcrumb Nav %>
  <div>
    <%= link_to items_path, class: "inline-flex items-center gap-2 text-xs font-bold text-secondary hover:text-primary transition-colors group" do %>
      <span class="material-symbols-outlined group-hover:-translate-x-1 transition-transform">arrow_back</span>
      <span class="font-label-caps text-xs uppercase tracking-wider">Back to Community Feed</span>
    <% end %>
  </div>

  <%# Two-column Layout %>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

    <%# Left Column: Image showcase & Neighbor Profile %>
    <div class="lg:col-span-7 space-y-8">
      <%# Main Image Showcase %>
      <div class="relative rounded-2xl overflow-hidden premium-card-shadow image-zoom bg-surface-container/35 aspect-[4/3] border border-outline-variant/15">
        <% if @item.images.attached? %>
          <%= image_tag @item.images.first.variant(resize_to_limit: [800, 600]),
              class: "w-full h-full object-cover transition-transform duration-700", alt: @item.name %>
        <% else %>
          <div class="w-full h-full flex flex-col items-center justify-center text-outline gap-2">
            <span class="material-symbols-outlined text-[64px] opacity-40">image</span>
            <span class="font-label-caps text-xs tracking-wider uppercase font-semibold">No photos uploaded</span>
          </div>
        <% end %>

        <% if @item.available? %>
          <div class="absolute top-4 left-4 bg-primary text-on-primary px-4 py-2 rounded-full font-label-caps text-xs shadow-lg font-black tracking-wider">
            POPULAR CHOICE
          </div>
        <% end %>
      </div>

      <%# Thumbnail Grid %>
      <% if @item.images.attached? && @item.images.count > 1 %>
        <div class="grid grid-cols-4 gap-4">
          <% @item.images.each do |image| %>
            <div class="rounded-xl overflow-hidden h-24 premium-card-shadow border border-outline-variant/20 cursor-pointer hover:border-primary transition-all">
              <%= image_tag image.variant(resize_to_fill: [150, 150]), class: "w-full h-full object-cover" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# About Box %>
      <div class="p-6 bg-surface-container-lowest rounded-2xl border border-outline-variant/20 premium-card-shadow space-y-3">
        <h3 class="font-headline-md text-xl text-on-surface">About This Item</h3>
        <p class="text-secondary font-body-base leading-relaxed text-sm">
          <%= @item.description %>
        </p>
      </div>

      <%# Neighbor Section %>
      <section class="space-y-6">
        <h2 class="font-headline-lg text-2xl text-on-surface">Meet Your Neighbor</h2>
        <div class="bg-surface-container-lowest p-6 sm:p-8 rounded-2xl border border-outline-variant/20 premium-card-shadow flex flex-col sm:flex-row gap-6">
          <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center flex-shrink-0 shadow-lg border-4 border-primary-container/20">
            <span class="text-white text-3xl font-black"><%= @item.user.name.first.upcase %></span>
          </div>
          <div class="flex-grow space-y-2.5">
            <div class="flex items-center gap-2">
              <h3 class="font-headline-md text-xl text-on-surface"><%= @item.user.name %></h3>
              <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings: 'FILL' 1;">verified</span>
            </div>
            <% if @item.user.neighborhood %>
              <p class="text-secondary font-body-base text-sm font-semibold italic">
                Member of <%= @item.user.neighborhood.name %>
              </p>
            <% end %>
            <div class="flex gap-6 text-sm font-semibold pt-2">
              <div>
                <span class="block font-black text-primary text-lg"><%= @item.user.items.count %></span>
                <span class="font-label-caps text-[9px] text-secondary opacity-70 tracking-widest">SHARED ITEMS</span>
              </div>
              <div class="w-px bg-outline-variant/30"></div>
              <div>
                <span class="block font-black text-primary text-lg">4.9</span>
                <span class="font-label-caps text-[9px] text-secondary opacity-70 tracking-widest">RATING</span>
              </div>
              <div class="w-px bg-outline-variant/30"></div>
              <div>
                <span class="block font-black text-primary text-lg">Member</span>
                <span class="font-label-caps text-[9px] text-secondary opacity-70 tracking-widest">STATUS</span>
              </div>
            </div>
          </div>
        </div>

        <%# Proximity Area Map representation %>
        <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/20 premium-card-shadow overflow-hidden relative min-h-[220px]">
          <div class="absolute inset-0 bg-slate-100 flex items-center justify-center">
            <div class="w-full h-full bg-gradient-to-br from-emerald-500/10 to-teal-500/10 flex items-center justify-center">
              <div class="w-32 h-32 rounded-full bg-primary/10 flex items-center justify-center animate-pulse">
                <div class="w-16 h-16 rounded-full bg-primary/25 flex items-center justify-center">
                  <span class="material-symbols-outlined text-primary text-3xl">location_on</span>
                </div>
              </div>
            </div>
          </div>
          <div class="absolute bottom-4 left-4 right-4 bg-surface/90 backdrop-blur-md p-4 rounded-xl flex items-center justify-between border border-outline-variant/10 shadow-sm">
            <div>
              <p class="font-label-caps text-[9px] text-secondary tracking-widest font-extrabold">PICKUP AREA</p>
              <p class="font-body-base text-xs font-bold text-on-surface">
                <%= @item.user.neighborhood ? @item.user.neighborhood.name : "Local neighborhood circle" %>
              </p>
            </div>
            <span class="material-symbols-outlined text-primary text-[20px]">directions</span>
          </div>
        </div>
      </section>
    </div>

    <%# Right Column: Booking & Details %>
    <div class="lg:col-span-5 space-y-6 sticky-sidebar-card">
      <div class="form-card p-6 space-y-6">
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <% if @item.available? %>
              <span class="bg-primary-container/10 text-on-primary-container px-3 py-1 rounded-full font-label-caps text-[10px] tracking-wider font-extrabold">
                AVAILABLE NOW
              </span>
            <% else %>
              <span class="bg-tertiary-container/10 text-on-tertiary-container px-3 py-1 rounded-full font-label-caps text-[10px] tracking-wider font-extrabold">
                ON LOAN
              </span>
            <% end %>
            <div class="flex items-center gap-1 text-primary">
              <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
              <span class="font-bold text-sm">4.9</span>
            </div>
          </div>

          <div class="flex justify-between items-start gap-4">
            <h1 class="font-headline-lg text-2xl sm:text-3xl text-on-surface leading-tight">
              <%= @item.name %>
            </h1>

            <% if @item.user_id == current_user&.id %>
              <%= link_to edit_item_path(@item), class: "p-2.5 rounded-xl border border-outline-variant/50 text-secondary hover:text-primary hover:border-primary transition-all duration-200" do %>
                <span class="material-symbols-outlined text-[20px]">edit</span>
              <% end %>
            <% end %>
          </div>

          <div class="flex items-center gap-2 text-secondary text-sm font-semibold">
            <span class="material-symbols-outlined text-[18px] text-outline">location_on</span>
            <span><%= @item.user.neighborhood ? @item.user.neighborhood.name : "Local Neighborhood" %></span>
          </div>

          <div class="flex items-center gap-3 text-xs font-bold pt-1 border-t border-outline-variant/10">
            <span class="text-outline">CONDITION:</span>
            <span class="badge <%= @item.condition == 'like_new' ? 'badge-success' : @item.condition == 'good' ? 'badge-info' : @item.condition == 'fair' ? 'badge-warning' : 'badge-neutral' %>">
              <%= @item.condition.titleize %>
            </span>
          </div>
        </div>

        <%# Safety Info %>
        <div class="p-5 bg-tertiary-container/5 rounded-2xl border border-tertiary/10 space-y-3">
          <div class="flex items-center gap-2 text-tertiary">
            <span class="material-symbols-outlined text-[20px]">gavel</span>
            <h3 class="font-label-caps text-[10px] tracking-wider font-extrabold uppercase">Safety & Usage Notes</h3>
          </div>
          <ul class="space-y-2 text-xs font-semibold text-secondary">
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
              Handle item with care and use proper safety equipment.
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
              Report any damage or wear to the lender immediately.
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
              Return in clean condition inside the original packaging.
            </li>
          </ul>
        </div>

        <%# Request form %>
        <% if user_signed_in? && @item.user_id != current_user.id && @item.available? %>
          <%= turbo_frame_tag "loan_form" do %>
            <div class="border-t border-outline-variant/20 pt-5 space-y-4" data-controller="booking">
              <h3 class="font-bold text-on-surface text-sm tracking-wider uppercase font-label-caps flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">calendar_today</span>
                Request to Borrow
              </h3>

              <%= form_with model: @loan, url: item_loans_path(@item), class: "space-y-4" do |f| %>
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <%= f.label :start_date, "Pick Up", class: "block text-[10px] font-bold text-secondary uppercase tracking-wider mb-1.5" %>
                    <%= f.date_field :start_date, min: Date.current,
                        class: "w-full px-3 py-2.5 rounded-xl border border-outline-variant/60 bg-surface text-sm font-semibold focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all",
                        data: { booking_target: "startDate", action: "change->booking#validateDates" } %>
                  </div>
                  <div>
                    <%= f.label :end_date, "Return By", class: "block text-[10px] font-bold text-secondary uppercase tracking-wider mb-1.5" %>
                    <%= f.date_field :end_date, min: Date.current + 1,
                        class: "w-full px-3 py-2.5 rounded-xl border border-outline-variant/60 bg-surface text-sm font-semibold focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all",
                        data: { booking_target: "endDate", action: "change->booking#validateDates" } %>
                  </div>
                </div>
                <div>
                  <%= f.label :message, "Note for lender", class: "block text-[10px] font-bold text-secondary uppercase tracking-wider mb-1.5" %>
                  <%= f.text_area :message, rows: 2, placeholder: "What's your project?",
                      class: "w-full px-3 py-2.5 rounded-xl border border-outline-variant/60 bg-surface text-sm font-semibold placeholder:text-outline focus:border-primary focus:ring-4 focus:ring-primary/10 resize-none transition-all" %>
                </div>
                <%= f.submit "SUBMIT REQUEST", class: "w-full py-3.5 bg-primary text-on-primary rounded-xl font-label-caps text-xs tracking-widest font-extrabold cursor-pointer transition-all hover:brightness-110 shadow-lg active:scale-95" %>
              <% end %>
            </div>
          <% end %>
        <% elsif !@item.available? %>
          <div class="p-4 rounded-xl bg-amber-50 dark:bg-amber-950/20 border border-amber-200/50 dark:border-amber-800/30 flex items-center gap-3">
            <span class="material-symbols-outlined text-amber-500">lock_clock</span>
            <p class="text-xs font-semibold text-amber-700 dark:text-amber-300">Currently on loan — check back later!</p>
          </div>
        <% end %>

        <%# Owner Pending Requests %>
        <% if @item.user_id == current_user&.id && @item.pending_requests.any? %>
          <div class="border-t border-outline-variant/20 pt-5 space-y-4">
            <h3 class="font-bold text-on-surface text-sm tracking-wider uppercase font-label-caps flex items-center gap-2">
              <span class="material-symbols-outlined text-primary">groups</span>
              Pending Requests (<%= @item.pending_requests.count %>)
            </h3>
            <div class="space-y-3">
              <% @item.pending_requests.includes(:borrower).each do |loan| %>
                <div class="bg-surface p-4 rounded-xl border border-outline-variant/30 space-y-3 shadow-sm">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-500 flex items-center justify-center shadow-sm">
                      <span class="text-white text-xs font-bold"><%= loan.borrower.name.first.upcase %></span>
                    </div>
                    <div>
                      <p class="font-bold text-xs text-on-surface"><%= loan.borrower.name %></p>
                      <p class="text-[10px] text-primary font-bold"><%= loan.start_date.strftime("%b %d") %> – <%= loan.end_date.strftime("%b %d") %></p>
                    </div>
                  </div>
                  <% if loan.message.present? %>
                    <p class="text-[11px] text-secondary italic bg-surface-container/50 p-2.5 rounded-lg border border-outline-variant/10">
                      "<%= loan.message %>"
                    </p>
                  <% end %>
                  <div class="flex gap-2 pt-1">
                    <%= button_to "Approve", approve_item_loan_path(@item, loan), method: :patch,
                        class: "flex-1 py-2 bg-primary text-on-primary rounded-lg font-label-caps text-[10px] font-extrabold tracking-wider hover:brightness-110 active:scale-95 cursor-pointer" %>
                    <%= button_to "Decline", decline_item_loan_path(@item, loan), method: :patch,
                        class: "px-4 py-2 border border-outline-variant/50 text-secondary rounded-lg font-label-caps text-[10px] font-extrabold tracking-wider hover:bg-surface-container/50 active:scale-95 cursor-pointer" %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>

</div>
