<%# Item Card Component — Premium Design %>
<div id="<%= dom_id(item) %>" class="premium-card flex flex-col h-full group">

  <%# Image Section %>
  <%= link_to item_path(item), class: "block relative overflow-hidden aspect-[4/3] bg-gradient-to-br from-slate-100 to-slate-50 dark:from-slate-800 dark:to-slate-850 image-zoom-container" do %>
    <% if item.images.attached? %>
      <%= image_tag item.thumbnail.variant(resize_to_fill: [400, 300]),
          class: "w-full h-full object-cover",
          loading: "lazy",
          alt: item.name %>
    <% else %>
      <div class="w-full h-full flex flex-col items-center justify-center text-slate-300 dark:text-slate-600 gap-2">
        <svg class="w-10 h-10 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span class="text-[10px] font-bold tracking-wider uppercase opacity-60">No photo</span>
      </div>
    <% end %>

    <%# Category Badge — Top Left %>
    <span class="absolute top-3 left-3 badge badge-success backdrop-blur-md bg-white/80 dark:bg-slate-900/80 shadow-sm">
      <%= item.category.titleize %>
    </span>

    <%# Loan Status Badge — Top Right %>
    <% unless item.available? %>
      <span class="absolute top-3 right-3 badge text-white bg-gradient-to-r from-amber-500 to-orange-500 border-0 shadow-md">
        On Loan
      </span>
    <% end %>
  <% end %>

  <%# Content Section %>
  <div class="p-4 sm:p-5 flex-1 flex flex-col justify-between gap-3">
    <div class="space-y-1.5">
      <%= link_to item_path(item), class: "block group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors duration-200" do %>
        <h3 class="font-bold text-slate-900 dark:text-white text-base tracking-tight leading-snug line-clamp-1">
          <%= item.name %>
        </h3>
      <% end %>
      <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2 leading-relaxed font-medium">
        <%= item.description %>
      </p>
    </div>

    <%# Footer: Owner + Condition %>
    <div class="flex items-center justify-between pt-3 border-t border-slate-100 dark:border-slate-800/60">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center shadow-sm">
          <span class="text-white text-[10px] font-bold"><%= item.user.name.first.upcase %></span>
        </div>
        <span class="text-xs font-semibold text-slate-600 dark:text-slate-400"><%= item.user.name.split.first %></span>
      </div>

      <span class="badge
        <%= item.condition == 'like_new' ? 'badge-success' :
            item.condition == 'good' ? 'badge-info' :
            item.condition == 'fair' ? 'badge-warning' :
            'badge-neutral' %>">
        <%= item.condition.titleize %>
      </span>
    </div>
  </div>
</div>
