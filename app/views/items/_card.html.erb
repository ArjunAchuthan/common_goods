<%# Item Card Component — Stitch Premium Design %>
<div id="<%= dom_id(item) %>" class="group bg-surface-container-lowest border border-outline-variant/20 rounded-2xl overflow-hidden smooth-lift premium-card-shadow flex flex-col h-full">

  <%# Image / Thumbnail Section %>
  <%= link_to item_path(item), class: "block relative overflow-hidden aspect-[4/3] bg-surface-container/30 image-zoom" do %>
    <% if item.images.attached? %>
      <%= image_tag item.thumbnail.variant(resize_to_fill: [400, 300]),
          class: "w-full h-full object-cover",
          loading: "lazy",
          alt: item.name %>
    <% else %>
      <div class="w-full h-full flex flex-col items-center justify-center text-outline gap-2">
        <span class="material-symbols-outlined text-[32px] opacity-40">image</span>
        <span class="font-label-caps text-[9px] tracking-wider uppercase font-semibold">No photo</span>
      </div>
    <% end %>

    <%# Availability Overlay Badge %>
    <% if item.available? %>
      <div class="absolute top-4 left-4 bg-primary/95 backdrop-blur-md text-on-primary px-3 py-1 rounded-full font-label-caps text-[9px] tracking-widest font-extrabold shadow-sm">AVAILABLE</div>
    <% else %>
      <div class="absolute top-4 left-4 bg-tertiary/95 backdrop-blur-md text-on-primary px-3 py-1 rounded-full font-label-caps text-[9px] tracking-widest font-extrabold shadow-sm">IN USE</div>
    <% end %>
  <% end %>

  <%# Card Info / Content Section %>
  <div class="p-5 flex-1 flex flex-col justify-between gap-4">
    <div class="space-y-1.5">
      <div class="flex justify-between items-start gap-2">
        <%= link_to item_path(item), class: "block group-hover:text-primary transition-colors duration-200" do %>
          <h3 class="font-body-lg text-base font-bold text-on-surface line-clamp-1 leading-snug">
            <%= item.name %>
          </h3>
        <% end %>
        <span class="font-label-caps text-xs font-black text-primary">FREE</span>
      </div>
      
      <p class="text-xs text-secondary line-clamp-2 leading-relaxed">
        <%= item.description %>
      </p>

      <%# Proximity / Location Badge %>
      <div class="flex items-center gap-1.5 text-secondary text-[11px] font-bold">
        <span class="material-symbols-outlined text-[16px] text-outline">location_on</span>
        <span>
          <%= item.user.neighborhood ? item.user.neighborhood.name : "Local Circle" %>
        </span>
      </div>
    </div>

    <%# Card Footer with Avatar and Condition %>
    <div class="flex items-center justify-between pt-3 border-t border-outline-variant/10">
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 rounded-full bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center shadow-sm">
          <span class="text-white text-[9px] font-black"><%= item.user.name.first.upcase %></span>
        </div>
        <span class="font-label-caps text-[10px] text-on-surface font-semibold"><%= item.user.name.split.first.upcase %></span>
      </div>

      <span class="badge <%= item.condition == 'like_new' ? 'badge-success' : item.condition == 'good' ? 'badge-info' : item.condition == 'fair' ? 'badge-warning' : 'badge-neutral' %>">
        <%= item.condition.titleize %>
      </span>
    </div>
  </div>
</div>

