<%# Items Index — Stitch Premium Discovery Page %>
<%
  category_icons = {
    "tools" => "construction",
    "garden" => "potted_plant",
    "kitchen" => "outdoor_grill",
    "sports" => "sports_tennis",
    "camping" => "camping",
    "electronics" => "devices",
    "books" => "book",
    "furniture" => "chair",
    "other" => "more_horiz"
  }
%>

<div class="space-y-12 animate-fade-in-up">

  <%# Hero Section with radial background gradients %>
  <section class="hero-gradient rounded-3xl py-16 px-6 sm:px-12 overflow-hidden border border-outline-variant/10 text-center space-y-6">
    <div class="space-y-3">
      <span class="font-label-caps text-xs text-primary bg-primary-container/10 px-4 py-1.5 rounded-full inline-block tracking-widest font-extrabold">NEIGHBORHOOD SHARING</span>
      <h1 class="font-display-hero text-3xl sm:text-4xl lg:text-5xl font-black text-on-surface max-w-3xl mx-auto leading-tight">
        Borrow a drill, a tent,<br/>or a blender.
      </h1>
      <p class="font-body-lg text-base sm:text-lg text-secondary max-w-xl mx-auto">
        Sustainable living starts next door. Access quality items shared by your community for free.
      </p>
    </div>

    <%# Search Bar with inline radius filter %>
    <div class="max-w-2xl mx-auto relative group" data-controller="search">
      <div class="absolute inset-0 bg-primary/5 blur-2xl rounded-full group-focus-within:bg-primary/10 transition-all"></div>
      <%= form_with url: search_items_path, method: :get, class: "relative", data: { turbo_frame: "items_grid" } do |f| %>
        <div class="relative flex items-center bg-surface-container-lowest border border-outline-variant/50 rounded-full p-1.5 shadow-lg focus-within:ring-4 focus-within:ring-primary/10 transition-all">
          <span class="material-symbols-outlined ml-4 text-outline">search</span>
          <%= f.text_field :query, value: params[:query], placeholder: "What do you need today?",
              class: "w-full bg-transparent border-none focus:ring-0 px-4 font-body-base text-on-surface placeholder:text-outline focus:outline-none focus:border-none focus:ring-transparent text-sm",
              data: { search_target: "input", action: "input->search#debounceSearch" } %>
          
          <%# Inline Radius Filter %>
          <div class="relative border-l border-outline-variant/30 pl-2 mr-2">
            <%= f.select :radius, options_for_select([["2 km", 2], ["5 km", 5], ["10 km", 10]], params[:radius] || 5),
                {},
                class: "bg-transparent border-none text-xs font-bold text-secondary focus:ring-0 cursor-pointer pr-7 py-1.5 focus:outline-none focus:border-none focus:ring-transparent",
                data: { action: "change->search#submit" } %>
          </div>

          <%= f.submit "FIND ITEMS", class: "bg-primary text-on-primary hover:brightness-110 px-5 sm:px-7 py-3 rounded-full font-label-caps text-xs tracking-wider transition-all active:scale-95 cursor-pointer font-bold" %>
        </div>
      <% end %>
    </div>

    <%# Category Filters Chips %>
    <div class="flex flex-wrap justify-center gap-2 pt-4">
      <%# All Category Chip %>
      <%= link_to root_path(query: params[:query], radius: params[:radius]), 
                  data: { turbo_frame: "items_grid" }, 
                  class: "flex items-center gap-2 px-5 py-2 rounded-full font-body-base text-sm font-semibold transition-all active:scale-95 #{params[:category].blank? ? 'bg-primary text-on-primary shadow-md' : 'bg-surface-container-lowest text-secondary border border-outline-variant/30 hover:border-primary hover:text-primary'}" do %>
        <span class="material-symbols-outlined text-[18px]">grid_view</span>
        All
      <% end %>

      <%# Dynamic Category Chips %>
      <% Item.categories.keys.each do |cat| %>
        <%= link_to root_path(category: cat, query: params[:query], radius: params[:radius]), 
                    data: { turbo_frame: "items_grid" }, 
                    class: "flex items-center gap-2 px-5 py-2 rounded-full font-body-base text-sm font-semibold transition-all active:scale-95 #{params[:category] == cat ? 'bg-primary text-on-primary shadow-md' : 'bg-surface-container-lowest text-secondary border border-outline-variant/30 hover:border-primary hover:text-primary'}" do %>
          <span class="material-symbols-outlined text-[18px]"><%= category_icons[cat] || 'grid_view' %></span>
          <%= cat.titleize %>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# Section Header & Grid %>
  <section class="space-y-6">
    <div class="flex justify-between items-end">
      <div>
        <h2 class="font-headline-lg text-2xl sm:text-3xl text-on-surface">Available Near You</h2>
        <p class="font-body-base text-sm text-secondary">Discover quality resources in your trust circle</p>
      </div>
    </div>

    <%# Items Grid Turbo Frame %>
    <%= turbo_frame_tag "items_grid" do %>
      <% if @items.any? %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 sm:gap-8 stagger-children">
          <% @items.each do |item| %>
            <%= render "items/card", item: item %>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state bg-surface-container-lowest rounded-3xl border border-outline-variant/20 shadow-sm py-16">
          <div class="empty-state-icon mx-auto">
            <span class="material-symbols-outlined text-primary text-4xl">inventory_2</span>
          </div>
          <h3 class="text-xl font-bold text-on-surface mt-4 mb-2">No items found</h3>
          <p class="text-secondary text-sm max-w-sm mx-auto leading-relaxed">
            No gear matches your search filters. Try broadening your criteria or list a new item!
          </p>
          <% if user_signed_in? %>
            <%= link_to new_item_path, class: "mt-6 inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary rounded-full font-label-caps text-xs tracking-wider transition-all hover:brightness-110 shadow-md active:scale-95" do %>
              <span class="material-symbols-outlined text-[16px]">add</span>
              SHARE AN ITEM
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </section>
</div>
