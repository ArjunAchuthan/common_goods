<%= form_with model: item, class: "space-y-5" do |f| %>
  <% if item.errors.any? %>
    <div class="bg-rose-50 dark:bg-rose-950/30 border border-rose-200 dark:border-rose-800/50 rounded-xl p-4 animate-fade-in-up">
      <ul class="text-xs text-rose-700 dark:text-rose-300 space-y-1 font-semibold">
        <% item.errors.full_messages.each do |msg| %>
          <li class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01"/></svg>
            <%= msg %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Item Name", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" %>
    <%= f.text_field :name, required: true, placeholder: "e.g., DeWalt Cordless Drill",
        class: "w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50 text-sm font-medium placeholder-slate-400 dark:placeholder-slate-500 focus:bg-white dark:focus:bg-slate-800 transition-all duration-200" %>
  </div>

  <div>
    <%= f.label :description, "Description", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" %>
    <%= f.text_area :description, rows: 4, required: true,
        placeholder: "Describe the item, any accessories included, and usage notes...",
        class: "w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50 text-sm font-medium placeholder-slate-400 dark:placeholder-slate-500 focus:bg-white dark:focus:bg-slate-800 resize-none transition-all duration-200" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :category, class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" %>
      <%= f.select :category, options_for_select(Item.categories.keys.map { |c| [c.titleize, c] }, item.category),
          { prompt: "Select category" },
          class: "w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50 text-sm font-medium text-slate-700 dark:text-slate-300 focus:bg-white dark:focus:bg-slate-800 transition-all duration-200 cursor-pointer" %>
    </div>
    <div>
      <%= f.label :condition, class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" %>
      <%= f.select :condition, options_for_select(Item.conditions.keys.map { |c| [c.titleize, c] }, item.condition),
          { prompt: "Select condition" },
          class: "w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50 text-sm font-medium text-slate-700 dark:text-slate-300 focus:bg-white dark:focus:bg-slate-800 transition-all duration-200 cursor-pointer" %>
    </div>
  </div>

  <div>
    <%= f.label :images, "Photos (up to 5)", class: "block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5" %>
    <div class="border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-xl p-6 text-center hover:border-emerald-400 dark:hover:border-emerald-600 transition-colors duration-200 cursor-pointer bg-slate-50/30 dark:bg-slate-800/20">
      <%= f.file_field :images, multiple: true, accept: "image/png,image/jpeg,image/webp",
          class: "w-full text-sm text-slate-500 dark:text-slate-400
            file:mr-4 file:py-2.5 file:px-5 file:rounded-xl file:border-0
            file:text-sm file:font-semibold
            file:bg-emerald-50 dark:file:bg-emerald-900/30
            file:text-emerald-700 dark:file:text-emerald-400
            hover:file:bg-emerald-100 dark:hover:file:bg-emerald-900/50
            file:cursor-pointer file:transition-colors" %>
      <p class="text-xs text-slate-400 mt-3 font-medium">PNG, JPEG, or WebP · Max 5MB each</p>
    </div>
  </div>

  <div class="pt-1">
    <%= f.submit item.persisted? ? "Update Item" : "List Item for Sharing",
        class: "w-full py-3 btn-primary text-sm font-bold cursor-pointer" %>
  </div>
<% end %>
