<%% # Search results - rendered via Turbo Stream %>
<%= turbo_frame_tag "items_grid" do %>
  <% if @items.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% @items.each do |item| %>
        <%= render "items/card", item: item %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <svg class="w-16 h-16 text-gray-300 dark:text-gray-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <h3 class="text-lg font-semibold text-gray-500 dark:text-gray-400">No items match your search</h3>
      <p class="text-gray-400 mt-1">Try different keywords or expand your radius.</p>
    </div>
  <% end %>
<% end %>
