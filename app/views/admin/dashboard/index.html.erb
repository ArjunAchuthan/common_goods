<%# Admin Dashboard - Captain Management Center %>
<div class="space-y-10 animate-fade-in-up">
  
  <%# Dashboard Header %>
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-200/50 dark:border-slate-800/50 pb-6">
    <div class="space-y-1">
      <h1 class="text-3xl font-black text-slate-950 dark:text-white tracking-tight">Admin Control Panel</h1>
      <p class="text-sm font-semibold text-slate-400">
        Managing neighborhood collective: <strong class="text-emerald-600 dark:text-emerald-450"><%= @neighborhood.name %></strong>
      </p>
    </div>
    
    <div>
      <span class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold uppercase tracking-wider rounded-xl bg-orange-50 dark:bg-orange-950/20 text-orange-700 dark:text-orange-400 border border-orange-200/30 dark:border-orange-900/40">
        🛡 <%= current_user.role.titleize %> Administrator
      </span>
    </div>
  </div>

  <%# Elegantly Styled Metrics Grid %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
    <% [
      { label: "Active Members", value: @stats[:total_members], icon: "👥", color: "from-emerald-500 to-teal-500 shadow-emerald-500/10" },
      { label: "Listed Assets", value: @stats[:total_items], icon: "📦", color: "from-indigo-500 to-violet-500 shadow-indigo-500/10" },
      { label: "Active Loans", value: @stats[:active_loans], icon: "🔄", color: "from-amber-500 to-orange-500 shadow-orange-500/10" },
      { label: "Moderated Flags", value: @stats[:flagged_items], icon: "⚠️", color: "from-rose-500 to-red-500 shadow-red-500/10" }
    ].each do |stat| %>
      <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200/50 dark:border-slate-800/50 p-6 shadow-sm flex flex-col justify-between min-h-[120px]">
        <div class="flex items-center justify-between">
          <span class="text-xs font-bold uppercase tracking-wider text-slate-400"><%= stat[:label] %></span>
          <span class="text-2xl font-black text-slate-900 dark:text-white"><%= stat[:value] %></span>
        </div>
        
        <div class="flex items-center gap-2 mt-4 pt-3 border-t border-slate-50 dark:border-slate-850/60">
          <div class="w-6 h-6 rounded-lg bg-gradient-to-tr <%= stat[:color] %> flex items-center justify-center text-xs">
            <%= stat[:icon] %>
          </div>
          <span class="text-[10px] font-bold text-slate-450 uppercase tracking-wider">Neighborhood Metric</span>
        </div>
      </div>
    <% end %>
  </div>

  <%# Quick Action Buttons %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
    <%= link_to admin_members_path, class: "premium-card block p-6 rounded-2xl shadow-sm border border-slate-200/50 dark:border-slate-800/50 group" do %>
      <h3 class="font-extrabold text-slate-900 dark:text-white text-base group-hover:text-emerald-500 dark:group-hover:text-emerald-455 transition-colors flex items-center gap-2">
        <span>👥</span> Manage Members
      </h3>
      <p class="text-xs font-semibold text-slate-400 mt-2 leading-relaxed">
        Verify registrations, promote captains, or manage neighborhood status.
      </p>
    <% end %>

    <%= link_to admin_flagged_items_path, class: "premium-card block p-6 rounded-2xl shadow-sm border border-slate-200/50 dark:border-slate-800/50 group" do %>
      <h3 class="font-extrabold text-slate-900 dark:text-white text-base group-hover:text-emerald-500 dark:group-hover:text-emerald-455 transition-colors flex items-center gap-2">
        <span>🚩</span> Flagged Items
      </h3>
      <p class="text-xs font-semibold text-slate-400 mt-2 leading-relaxed">
        Moderate listed items, review flag notices, and coordinate quality control.
      </p>
    <% end %>

    <%= link_to new_invitation_path, class: "premium-card block p-6 rounded-2xl shadow-sm border border-slate-200/50 dark:border-slate-800/50 group" do %>
      <h3 class="font-extrabold text-slate-900 dark:text-white text-base group-hover:text-emerald-500 dark:group-hover:text-emerald-455 transition-colors flex items-center gap-2">
        <span>✉️</span> Invite Neighbors
      </h3>
      <p class="text-xs font-semibold text-slate-400 mt-2 leading-relaxed">
        Generate invite tokens and dispatch invitation emails to verified neighbors.
      </p>
    <% end %>
  </div>

  <%# Lists Section: Recent activity %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    
    <%# Recent Members %>
    <div class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-200/50 dark:border-slate-800/50 shadow-sm overflow-hidden flex flex-col justify-between">
      <div class="p-6 border-b border-slate-100 dark:border-slate-800/80">
        <h2 class="font-extrabold text-slate-900 dark:text-white text-lg tracking-tight">Recent Member Registrations</h2>
      </div>
      
      <div class="divide-y divide-slate-100 dark:divide-slate-800/80 flex-1">
        <% @recent_members.each do |member| %>
          <div class="p-5 flex items-center justify-between hover:bg-slate-50/40 dark:hover:bg-slate-905/40 transition-colors">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-violet-500 to-fuchsia-500 flex items-center justify-center shadow-inner">
                <span class="text-white text-xs font-bold uppercase"><%= member.name.first %></span>
              </div>
              <div>
                <p class="text-sm font-bold text-slate-900 dark:text-white leading-snug"><%= member.name %></p>
                <p class="text-xs text-slate-400 truncate"><%= member.email %></p>
              </div>
            </div>
            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Joined <%= time_ago_in_words(member.created_at) %> ago</span>
          </div>
        <% end %>
      </div>
    </div>

    <%# Recent Items %>
    <div class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-200/50 dark:border-slate-800/50 shadow-sm overflow-hidden flex flex-col justify-between">
      <div class="p-6 border-b border-slate-100 dark:border-slate-800/80">
        <h2 class="font-extrabold text-slate-900 dark:text-white text-lg tracking-tight">Recent Shared Goods</h2>
      </div>
      
      <div class="divide-y divide-slate-100 dark:divide-slate-800/80 flex-1">
        <% @recent_items.each do |item| %>
          <div class="p-5 flex items-center justify-between hover:bg-slate-50/40 dark:hover:bg-slate-905/40 transition-colors">
            <div class="space-y-1">
              <%= link_to item.name, item_path(item), class: "text-sm font-bold text-slate-900 dark:text-white hover:text-emerald-500 transition-colors" %>
              <p class="text-[11px] font-semibold text-slate-400">
                by <%= item.user.name %> · <span class="uppercase tracking-wider text-[10px]"><%= item.category.titleize %></span>
              </p>
            </div>
            
            <div class="flex items-center gap-2.5">
              <% if item.flagged? %>
                <span class="text-[9px] font-extrabold uppercase tracking-wider px-2 py-0.5 rounded-lg bg-rose-50 dark:bg-rose-950/20 text-rose-700 dark:text-rose-455 border border-rose-100 dark:border-rose-900/40">Moderated</span>
              <% end %>
              <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider"><%= time_ago_in_words(item.created_at) %> ago</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>
