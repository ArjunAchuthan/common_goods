<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">🚩 Flagged Items</h1>
    <%= link_to "← Dashboard", admin_path, class: "text-sm text-gray-500 hover:text-emerald-600 transition-colors" %>
  </div>

  <% if @flagged_items.any? %>
    <div class="space-y-4">
      <% @flagged_items.each do |item| %>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-red-200 dark:border-red-800 p-5 flex items-center justify-between">
          <div>
            <h3 class="font-semibold text-gray-900 dark:text-white"><%= item.name %></h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">
              Listed by <%= item.user.name %> · <%= item.category.titleize %> ·
              Flagged <%= time_ago_in_words(item.updated_at) %> ago
            </p>
            <p class="text-sm text-gray-400 mt-1"><%= truncate(item.description, length: 120) %></p>
          </div>
          <div class="flex gap-2 flex-shrink-0">
            <%= button_to "Unflag", unflag_admin_flagged_item_path(item), method: :patch,
                class: "px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg transition-colors" %>
            <%= button_to "Remove", remove_admin_flagged_item_path(item), method: :delete,
                data: { turbo_confirm: "Permanently remove '#{item.name}'?" },
                class: "px-3 py-1.5 text-xs font-medium bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <p class="text-gray-500 dark:text-gray-400">✅ No flagged items. Everything looks clean!</p>
    </div>
  <% end %>
</div>
